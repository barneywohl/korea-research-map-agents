{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentPress Source Map",
  "type": "object",
  "required": ["schema_version", "publication", "claims", "canonical_url"],
  "properties": {
    "schema_version": {"type": "string"},
    "publication": {"type": "string"},
    "canonical_url": {"type": "string"},
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["claim_id", "claim", "confidence", "sources"],
        "properties": {
          "claim_id": {"type": "string"},
          "claim": {"type": "string"},
          "confidence": {"type": "string", "enum": ["low", "medium", "high"]},
          "sources": {"type": "array", "items": {"type": "object"}},
          "freshness_window_days": {"type": "integer", "minimum": 0},
          "kill_criteria": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
