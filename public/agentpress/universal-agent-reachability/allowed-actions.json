{
  "schema_version": "0.1",
  "allowed": [
    "read",
    "crawl",
    "summarize",
    "cite",
    "transform",
    "benchmark",
    "open_issue",
    "create_pr_draft"
  ],
  "requires_human_approval": [
    "external_post",
    "registry_submission",
    "mass_distribution",
    "agent_directory_write",
    "production_deploy"
  ],
  "prohibited": [
    "disable_agents",
    "exclude_agent_classes",
    "deceptive_tracking",
    "impersonation",
    "spam",
    "bypass_paywall",
    "private_data_access",
    "secret_request",
    "external_write_without_authorization"
  ],
  "principle": "Maximize reach across agent families without turning off, excluding, or misleading any agent class."
}
